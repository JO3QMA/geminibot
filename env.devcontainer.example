# ========================================
# Discord-Gemini Bot Development Environment
# ========================================

# Discord設定
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Gemini設定
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro
GEMINI_MAX_TOKENS=1000
GEMINI_TEMPERATURE=0.7

# 開発用データベース設定
POSTGRES_PORT=5432
POSTGRES_DB=geminibot_dev
POSTGRES_USER=geminibot_dev
POSTGRES_PASSWORD=devpassword
POSTGRES_SSL_MODE=disable

# 開発用Redis設定
REDIS_PORT=6379
REDIS_PASSWORD=devpassword
REDIS_DB=0
REDIS_MAX_MEMORY=256mb
REDIS_MAX_MEMORY_POLICY=allkeys-lru

# Bot設定
BOT_SYSTEM_PROMPT=あなたは親切で役立つアシスタントです。
BOT_MAX_CONTEXT_LENGTH=4000
BOT_MAX_HISTORY_LENGTH=50
BOT_REQUEST_TIMEOUT=30s

# ログ設定
LOG_LEVEL=debug
LOG_FORMAT=json

# アプリケーション設定
APP_ENV=development
APP_DEBUG=true
